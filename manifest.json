{
  "manifest_version": 3,
  "name": "DispLyrics",
  "version": "1.0",
  "description": "Add lyrics to spotify without premium",
  "content_scripts": [
      {
        "js": [
          "scripts/content.js",
          "scripts/lyricsContainer.js"
        ],
        "matches": [
          "https://open.spotify.com/*",
          "https://open.spotify.com/lyrics/"
        ]
      }
    ],
    "action": {
    "default_popup": "popup/popup.html"
    },
    "icons": {
    "16": "assets/images/spoti icon-16.png",
    "32": "assets/images/spoti icon-32.png",
    "48": "assets/images/spoti icon-48.png", 
    "128": "assets/images/spoti icon-128.png"
  }
}